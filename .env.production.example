# Production template — copy to `.env` in repo root before:
#   docker compose -f docker-compose.prod.yml up -d --build
#
# Never commit the filled `.env`.

APP_ENV=production
SECRET_KEY=
PII_ENCRYPTION_KEY=

# Public HTTPS URL (must match DOMAIN below)
PUBLIC_APP_URL=https://linkswiss.ch
DOMAIN=linkswiss.ch
TRUSTED_HOSTS=linkswiss.ch,www.linkswiss.ch

# Public UI features (off by default in production)
PUBLIC_SEARCH_ENABLED=true
PUBLIC_SIGNUP_ENABLED=true
SIGNUP_AUTO_VERIFY=false

# Database password (used by postgres service + DATABASE_URL override in compose)
POSTGRES_PASSWORD=

# Admin — generate hash: python scripts/generate_admin_hash.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

RATE_LIMIT=60/minute

# WhatsApp webhook (Meta → https://linkswiss.ch/api/v1/webhooks/whatsapp)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_INBOUND_AUTO_VERIFY=true
WHATSAPP_VERIFY_KEYWORD=OK

# Email
NOTIFIER_MODE=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Live ingest — keep false until legal review
INGEST_DISPATCH_ALERTS=false
INGEST_HOMEGATE_LIVE=false
INGEST_JOBS_LIVE=false
INGEST_FLATFOX_LIVE=false
INGEST_IMMOSCOUT_LIVE=false
INGEST_NEWHOME_LIVE=false
INGEST_ANIBIS_LIVE=false
INGEST_JOBUP_LIVE=false

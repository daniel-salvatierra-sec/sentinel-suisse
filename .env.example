# Application
APP_ENV=development
SECRET_KEY=

# PII encryption at rest (Phase 8) — generate: python scripts/generate_pii_key.py
PII_ENCRYPTION_KEY=

# API (Phase 2 — localhost only)
API_HOST=127.0.0.1
API_PORT=8000
RATE_LIMIT=30/minute

# Database
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel_suisse

# Redis
REDIS_URL=redis://localhost:6379/0

# Admin (Phase 2) — generate hash: python scripts/generate_admin_hash.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# WhatsApp Cloud API (Phase 7) — Meta Graph API temporary token for dev
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Auto-dispatch alerts after ingest when new listings are created (Phase 7)
INGEST_DISPATCH_ALERTS=false

# Homegate live ingest (Phase 13) — disabled by default; review ToS/robots.txt first
INGEST_HOMEGATE_LIVE=false
INGEST_RATE_LIMIT_SECONDS=3
HOMEGATE_SEARCH_URL=https://www.homegate.ch/mieten/immobilien/kanton-genf/trefferliste

# jobs.ch live ingest (Phase 14) — disabled by default
INGEST_JOBS_LIVE=false
JOBS_SEARCH_URL=https://www.jobs.ch/en/vacancies/?location=Geneva

# Flatfox live ingest (Phase 20) — disabled by default
INGEST_FLATFOX_LIVE=false
FLATFOX_SEARCH_URL=https://flatfox.ch/en/search/?place=Geneva

# ImmoScout24 live ingest (Phase 21) — disabled by default
INGEST_IMMOSCOUT_LIVE=false
IMMOSCOUT_SEARCH_URL=https://www.immoscout24.ch/fr/immobilier/louer/lieu-geneve

# Notifier (Phase 6) — auto | console | smtp
NOTIFIER_MODE=auto

# Email (Phase 6) — e.g. Mailtrap for dev: sandbox.smtp.mailtrap.io
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
